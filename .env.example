# ── Telegram Alerts (Required for alerts) ─────────────────────────────────
# Create a bot via @BotFather on Telegram, get the token.
# Get your chat_id by messaging @userinfobot
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Database ───────────────────────────────────────────────────────────────
# Path to SQLite database file (default: buzzflow.db in project root)
BUZZFLOW_DB=buzzflow.db

# ── Legacy API Keys (Optional - only needed for old buzz_engine.py) ────────
# These are NO LONGER required for the v2 scanner (scanner_v2.py)
# The new system uses Google News RSS which is free and has no limits.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=BuzzFlow/2.0
NEWS_API_KEY=

# ── Instructions ───────────────────────────────────────────────────────────
# 1. Copy this file to .env
# 2. Fill in TELEGRAM_TOKEN and TELEGRAM_CHAT_ID for alerts
# 3. For GitHub Actions: add TELEGRAM_TOKEN and TELEGRAM_CHAT_ID as repository secrets
# 4. Never commit your .env file to version control
